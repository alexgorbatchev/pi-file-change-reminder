{
  "name": "pi-file-change-reminder",
  "version": "2.0.0",
  "description": "Pi extension that injects reminder messages when specific files are modified.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexgorbatchev/pi-file-change-reminder.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "reminder"
  ],
  "files": [
    "fileChangeReminderExtension.ts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./fileChangeReminderExtension.ts"
    ]
  },
  "dependencies": {
    "picomatch": "^4.0.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@alexgorbatchev/typescript-ai-policy": "^1.0.1",
    "@mariozechner/pi-coding-agent": "^0.61.1",
    "@types/picomatch": "^4.0.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.58.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "format": "bash scripts/format.sh",
    "format:check": "bash scripts/format-check.sh",
    "lint": "bash scripts/lint.sh",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run verify:pi-load",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:pi-load": "PI_OFFLINE=1 pi --no-extensions -e ./fileChangeReminderExtension.ts --list-models > /dev/null",
    "prepublishOnly": "npm run check"
  }
}
