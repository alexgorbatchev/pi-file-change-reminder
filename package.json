{
  "name": "pi-file-change-reminder",
  "version": "2.0.0",
  "description": "Pi extension that injects reminder messages when specific files are modified.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexgorbatchev/pi-file-change-reminder.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "reminder"
  ],
  "files": [
    "src/fileChangeReminderExtension.ts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/fileChangeReminderExtension.ts"
    ]
  },
  "dependencies": {
    "picomatch": "^4.0.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@alexgorbatchev/typescript-ai-policy": "^1.0.5",
    "@mariozechner/pi-coding-agent": "0.65.2",
    "@types/picomatch": "^4.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "6.0.2",
    "@types/node": "25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260407.1"
  },
  "scripts": {
    "fmt": "bun --bun oxfmt --write .",
    "fmt:check": "bun --bun oxfmt --check .",
    "check": "bun run fmt:check && bun --bun oxlint . && tsgo --noEmit",
    "test": "PI_OFFLINE=1 bun x pi --no-extensions -e ./src/fileChangeReminderExtension.ts --list-models > /dev/null 2>&1",
    "test:local": "bun x pi -e ./src/fileChangeReminderExtension.ts"
  }
}
